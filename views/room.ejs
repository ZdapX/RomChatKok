<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Public Chat Room</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .chat-container { height: calc(100vh - 160px); overflow-y: auto; }
        .bubble { max-width: 75%; padding: 8px 12px; border-radius: 12px; margin-bottom: 8px; position: relative; }
        .bubble-left { background: #ffffff; align-self: flex-start; border-bottom-left-radius: 2px; }
        .bubble-right { background: #dcf8c6; align-self: flex-end; border-bottom-right-radius: 2px; }
    </style>
</head>
<body class="bg-gray-200 font-sans">

    <div class="max-w-lg mx-auto bg-white shadow-lg h-screen flex flex-col">
        <!-- Header -->
        <div class="bg-[#075e54] text-white p-4 flex items-center shadow-md">
            <h1 class="font-bold text-lg">Grup Publik Chat</h1>
        </div>

        <!-- Chat Area -->
        <div id="chatBox" class="chat-container p-4 flex flex-col bg-[#e5ddd5]">
            <!-- Pesan akan muncul di sini -->
        </div>

        <!-- Input Area -->
        <div class="p-3 bg-gray-100 flex flex-col gap-2 border-t">
            <input type="text" id="userName" placeholder="Isi nama kamu..." class="p-2 border rounded-lg text-sm focus:outline-none">
            <div class="flex gap-2">
                <input type="text" id="messageInput" placeholder="Ketik pesan..." class="flex-1 p-2 border rounded-lg focus:outline-none">
                <button onclick="sendMessage()" class="bg-[#128c7e] text-white px-4 py-2 rounded-lg font-bold">Kirim</button>
            </div>
        </div>
    </div>

    <script>
        const chatBox = document.getElementById('chatBox');
        const userNameInput = document.getElementById('userName');
        const messageInput = document.getElementById('messageInput');

        // Load Nama dari LocalStorage jika ada
        if(localStorage.getItem('chat_name')) {
            userNameInput.value = localStorage.getItem('chat_name');
        }

        async function fetchMessages() {
            try {
                const res = await fetch('/api/messages');
                const messages = await res.json();
                
                const currentName = userNameInput.value.trim();
                chatBox.innerHTML = '';

                messages.forEach(msg => {
                    const isMe = msg.name === currentName;
                    const div = document.createElement('div');
                    div.className = isMe ? 'bubble bubble-right shadow-sm' : 'bubble bubble-left shadow-sm';
                    
                    div.innerHTML = `
                        <div class="text-[10px] font-bold text-gray-600 ${isMe ? 'text-right' : 'text-left'}">${msg.name}</div>
                        <div class="text-md">${msg.text}</div>
                        <div class="text-[9px] text-gray-500 text-right">${new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
                    `;
                    chatBox.appendChild(div);
                });
                chatBox.scrollTop = chatBox.scrollHeight;
            } catch (err) {
                console.error("Error fetching:", err);
            }
        }

        async function sendMessage() {
            const name = userNameInput.value.trim();
            const text = messageInput.value.trim();

            if(!name || !text) return alert("Nama dan pesan harus diisi!");

            localStorage.setItem('chat_name', name); // Simpan nama

            await fetch('/api/messages', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, text })
            });

            messageInput.value = '';
            fetchMessages();
        }

        // Auto Refresh setiap 3 detik agar terlihat real-time sederhana
        setInterval(fetchMessages, 3000);
        fetchMessages();

        // Support Enter key
        messageInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") sendMessage();
        });
    </script>
</body>
</html>
